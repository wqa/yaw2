server {
    server_name fnlr.se www.fnlr.se;

    # Secret download area — static, served directly by nginx (range/resume).
    location /5f0813a105c5acab/ {
        alias /home/fnlr/yaw-anchor/dist/;
        index download.html;
        autoindex off;
        add_header X-Robots-Tag "noindex, nofollow" always;
    }

    # YAW/2 web client — static files behind a secret path + basic auth.
    # Server only serves HTML/JS; secrets live in the browser's localStorage,
    # mesh data is peer-to-peer (server stays a pure anchor).
    location /1bf4b6c531153bfd/ {
        alias /home/fnlr/yaw-web/;
        index index.html;
        auth_basic "Restricted";
        auth_basic_user_file /etc/nginx/.htpasswd-yaw;
        add_header X-Robots-Tag "noindex, nofollow" always;
    }

    # YAW/2 signaling — WebSocket proxy to the local signaling server.
    # Carries only sealed offer/answer/ICE blobs; never file data.
    location /4802f621018e1968/signal {
        proxy_pass http://127.0.0.1:8077;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Everything else -> the app: innocuous cover page at / and the hidden API.
    location / {
        proxy_pass http://127.0.0.1:8055;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 4m;
    }

    listen [2a03:b0c0:0:1010::15:1]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/bombkatten.se-0001/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/bombkatten.se-0001/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.fnlr.se) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = fnlr.se) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    listen [2a03:b0c0:0:1010::15:1]:80;
    server_name fnlr.se www.fnlr.se;
    return 404; # managed by Certbot
}
