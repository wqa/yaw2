# Example nginx vhost for a YAW anchor (sanitized template).
#
# Copy to the real vhost file (gitignored) and substitute the placeholders:
#   <anchor-host>     your public hostname (doubles as an innocuous cover site)
#   <signal-path>     unguessable path segment for the signaling WebSocket
#   <app-path>        unguessable path segment for the web client
#   <download-path>   unguessable path segment for any static download area
# Basic-auth users go in /etc/nginx/.htpasswd-yaw (htpasswd, not in the repo).
# Rotating these secrets: see ROTATING_KEYS.md.

server {
    server_name <anchor-host> www.<anchor-host>;

    # Optional secret download area — static, served directly by nginx.
    location /<download-path>/ {
        alias /home/<deploy-user>/yaw-download/;
        index download.html;
        autoindex off;
        add_header X-Robots-Tag "noindex, nofollow" always;
    }

    # YAW/2 web client — static files behind a secret path + basic auth.
    # Server only serves HTML/JS; secrets live in the browser's localStorage,
    # mesh data is peer-to-peer (server stays a pure anchor).
    location /<app-path>/ {
        alias /home/<deploy-user>/yaw-web/;
        index index.html;
        auth_basic "Restricted";
        auth_basic_user_file /etc/nginx/.htpasswd-yaw;
        add_header X-Robots-Tag "noindex, nofollow" always;
    }

    # YAW/2 signaling — WebSocket proxy to the local signaling server.
    # Carries only sealed offer/answer/ICE blobs; never file data.
    # X-Real-IP lets the signaling server log the true peer IP (yawpeers).
    location /<signal-path>/signal {
        proxy_pass http://127.0.0.1:8077;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Everything else -> a static, innocuous cover page (no app server).
    location / {
        root /home/<deploy-user>/cover;
        index index.html;
    }

    listen 443 ssl;            # TLS via your certificate (e.g. Certbot)
    # ssl_certificate ... ; ssl_certificate_key ... ;
}
